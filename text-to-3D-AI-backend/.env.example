# ============================================
# OptiForge3D Backend Environment Configuration
# ============================================
# Copy this file to .env and update with your actual values.
# NEVER commit .env to version control!

# --- PostgreSQL ---
POSTGRES_USER=optiforge_user
POSTGRES_PASSWORD=change_this_secure_password_123
POSTGRES_DB=optiforge_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=change_this_redis_password_456

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_this_minio_password_789
MINIO_SECURE=false
MINIO_BUCKET_RAW_UPLOADS=raw-uploads
MINIO_BUCKET_GENERATED_MODELS=generated-models

# --- Celery Task Queue ---
# Broker and backend default to the Redis URL built from REDIS_HOST/PORT above.
# Only override if you need a separate Redis instance for the task queue.
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Application ---
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]
