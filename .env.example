# OptiForge3D Environment Configuration Template
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!

# ============================================
# PostgreSQL Configuration
# ============================================
POSTGRES_USER=optiforge_user
POSTGRES_PASSWORD=change_this_secure_password_123
POSTGRES_DB=optiforge_db
POSTGRES_PORT=5432

# ============================================
# Redis Configuration
# ============================================
REDIS_PORT=6379
# Redis password (optional but recommended)
# Uncomment and set for production
# REDIS_PASSWORD=change_this_redis_password_456

# ============================================
# MinIO Configuration
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_this_minio_password_789
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Default region for MinIO
MINIO_REGION=us-east-1

# ============================================
# Docker Network Configuration
# ============================================
NETWORK_NAME=optiforge_network

# ============================================
# Volume Names
# ============================================
POSTGRES_VOLUME=optiforge_postgres_data
REDIS_VOLUME=optiforge_redis_data
MINIO_VOLUME=optiforge_minio_data

# ============================================
# Application Configuration (for future use)
# ============================================
# These will be used by backend/frontend in later steps
APP_ENV=development
DEBUG=true

# ============================================
# MinIO Buckets (for reference)
# ============================================
# These buckets will be created automatically:
# - raw-uploads: User uploaded 3D model files
# - generated-models: Optimized 3D model outputs
